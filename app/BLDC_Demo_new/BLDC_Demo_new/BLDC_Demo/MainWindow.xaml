<Window x:Class="BLDC_Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BLDC_Demo"
        Title="BLDC Demo Control Panel"
        Width="1360" Height="790"
        MinWidth="800" MinHeight="600"
        Background="#E4EAF6"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#00C8FF"/>
        <SolidColorBrush x:Key="TextBrush"   Color="#E4EAF6"/>
        <SolidColorBrush x:Key="MutedBrush"  Color="#5A6A8A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#C8D0E4"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- TOP BAR -->
            <RowDefinition Height="8"/>
            <!-- spacer  -->
            <RowDefinition Height="*"/>
            <!-- CONTENT -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════
             TOP BAR
             ═══════════════════════════════════════════════ -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <Border x:Name="ConnectionPill" DockPanel.Dock="Right"
                    Background="#1E293B" CornerRadius="12"
                    Padding="12,4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="ConnectionDot" Width="7" Height="7"
                             Fill="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="ConnectionLabel" Text="NOT CONNECTED"
                               FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                               Foreground="#64748B" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <TextBlock Text="v2.4.1 — MDR INTERFACE"
                       FontFamily="Consolas" FontSize="10"
                       Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center" Margin="0,0,14,0"
                       DockPanel.Dock="Right"/>
        </DockPanel>

        <!-- ═══════════════════════════════════════════════
             MAIN CONTENT
             Col 0 : Left panel split into two rows
             Col 2 : AppShellControl (right stack)
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <!-- left  -->
                <ColumnDefinition Width="16"/>
                <!-- gutter -->
                <ColumnDefinition Width="*"/>
                <!-- right  -->
            </Grid.ColumnDefinitions>

            <!-- ── LEFT COLUMN : split into two rows ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="709"/>
                    <!-- top row -->
                    
                    <!-- gutter -->
                    <RowDefinition Height="*"/>
                    <!-- bottom row -->
                </Grid.RowDefinitions>

                <!-- Top half of left column -->
                <local:CommMotorSelectControl x:Name="CommMotorSelect"
                                              Grid.Row="0"/>

             
            </Grid>
         
            <!-- ── RIGHT : AppShellControl owns Network + MDR + Motor ── -->
            <local:AppShellControl x:Name="MainShell"
                                   Grid.Column="2"/>
        </Grid>
    </Grid>
</Window>