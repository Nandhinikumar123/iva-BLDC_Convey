<UserControl x:Class="YourNamespace.FirmwareUploadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="720" d:DesignHeight="520"
             Background="#F0F0F0" Height="649"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <!-- Classic Windows button style -->
        <Style x:Key="ClassicButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="Height" Value="23"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5F1FB"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CCE4F7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F4F4F4"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#C8C8C8"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Classic TextBox style -->
        <Style x:Key="ClassicTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ABABAB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="23"/>
        </Style>

        <!-- Classic ListBox style -->
        <Style x:Key="ClassicListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ABABAB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Output TextBox style -->
        <Style x:Key="OutputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ABABAB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,8,10,10">
        <Grid.RowDefinitions>
            <!-- Row 0: Firmware .BIN file location label -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: File path textbox + Browse button -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Selected Devices label -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Device list + action buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Note label -->
            <RowDefinition Height="Auto"/>
            <!-- Row 5: Output label -->
            <RowDefinition Height="Auto"/>
            <!-- Row 6: Output text area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Label -->
        <TextBlock Grid.Row="0"
                   Text="Firmware .BIN file location:"
                   Margin="0,0,0,3"
                   VerticalAlignment="Center"/>

        <!-- Row 1: File path + Browse -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtFirmwarePath"
                     Grid.Column="0"
                     Style="{StaticResource ClassicTextBoxStyle}"
                     Margin="0,0,5,0"/>

            <Button x:Name="BtnBrowse"
                    Grid.Column="1"
                    Content="Browse..."
                    Style="{StaticResource ClassicButtonStyle}"
                    MinWidth="80"
                    Click="BtnBrowse_Click"/>
        </Grid>

        <!-- Row 2: Selected Devices label -->
        <TextBlock Grid.Row="2"
                   Text="Selected Devices:"
                   Margin="0,0,0,3"
                   VerticalAlignment="Center"/>

        <!-- Row 3: Device ListBox + Upload buttons -->
        <Grid Grid.Row="3" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Device list -->
            <ListBox x:Name="LstDevices"
                     Grid.Column="0"
                     Style="{StaticResource ClassicListBoxStyle}"
                     Height="80"
                     SelectionMode="Extended"/>

            <!-- Buttons panel -->
            <StackPanel Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Top">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Upload One -->
                    <Button x:Name="BtnUploadOne"
                            Grid.Column="0"
                            Content="Upload One"
                            Style="{StaticResource ClassicButtonStyle}"
                            MinWidth="90"
                            Margin="0,0,0,0"
                            Click="BtnUploadOne_Click"/>

                    <!-- Abort Uploading (right-aligned) -->
                    <Button x:Name="BtnAbortUploading"
                            Grid.Column="2"
                            Content="Abort Uploading"
                            Style="{StaticResource ClassicButtonStyle}"
                            MinWidth="110"
                            IsEnabled="False"
                            Click="BtnAbortUploading_Click"/>
                </Grid>

                <!-- Upload ALL -->
                <Button x:Name="BtnUploadAll"
                        Content="Upload ALL"
                        Style="{StaticResource ClassicButtonStyle}"
                        MinWidth="90"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,0"
                        Click="BtnUploadAll_Click"/>
            </StackPanel>
        </Grid>

        <!-- Row 4: Note -->
        <TextBlock Grid.Row="4"
                   Text="NOTE: You can select multiple devices via Network Services, &quot;Upgrade FW&quot; button."
                   Margin="0,0,0,4"
                   TextWrapping="Wrap"
                   FontSize="11"/>

        <!-- Row 5: Output label -->
        <TextBlock Grid.Row="5"
                   Text="Output:"
                   Margin="0,0,0,3"
                   VerticalAlignment="Center"/>

        <!-- Row 6: Output area -->
        <TextBox x:Name="TxtOutput"
                 Grid.Row="6"
                 Style="{StaticResource OutputTextBoxStyle}"
                 MinHeight="200"/>

    </Grid>
</UserControl>
