<UserControl x:Class="BLDC_Demo.AuxUsage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#E4EAF6"
             FontFamily="Segoe UI"
              Height="649"
             FontSize="12">


    <Border BorderBrush="#888888"
            BorderThickness="1"
            Margin="10,10,10,10"
            Background="White">
        <StackPanel Margin="8,8,8,8">

            <!-- ══ Control Port Inputs ══ -->
            <GroupBox Header="Control Port Inputs" FontSize="11" FontWeight="Black" Style="{StaticResource GroupBoxStyle}"   Foreground="{StaticResource AccentBrush}" Height="105">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Zone Invert -->
                    <GroupBox Grid.Column="0"
                              Header="Left Zone Invert"
                              Style="{StaticResource GroupBoxStyle}" FontWeight="Medium"  Foreground="{StaticResource AccentBrush}"
                              Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal" Margin="2,2,2,2">
                            <CheckBox x:Name="ChkLZI_Accumulation"
                                      Content="Accumulation"  Foreground="#5A6A8A" FontWeight="Medium"
                                      Margin="0,0,16,0"/>
                            <CheckBox x:Name="ChkLZI_InfeedDischarge"  Foreground="#5A6A8A"
                                      Content="Infeed/Discharge"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Right Zone Invert -->
                    <GroupBox Grid.Column="1"
                              Header="Right Zone Invert" FontWeight="Medium"  Foreground="{StaticResource AccentBrush}"
                              Style="{StaticResource GroupBoxStyle}"
                              Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal" Margin="2,2,2,2">
                            <CheckBox x:Name="ChkRZI_Accumulation"
                                      Content="Accumulation"  Foreground="#5A6A8A"
                                      Margin="0,0,16,0"/>
                            <CheckBox x:Name="ChkRZI_InfeedDischarge"
                                      Content="Infeed/Discharge"  Foreground="#5A6A8A"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </GroupBox>

            <!-- ══ Control Port Outputs ══ -->
            <GroupBox Header="Control Port Outputs"  FontWeight="Black" FontSize="11"  Foreground="{StaticResource AccentBrush}" Style="{StaticResource GroupBoxStyle}" Height="101">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Zone -->
                    <GroupBox Grid.Column="0"
                              Header="Left Zone"
                           Foreground="#5A6A8A" FontWeight="Medium"  
                              Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal" Margin="2,2,2,2">
                            <CheckBox x:Name="ChkLZ_Invert"
                                      Content="Invert"  Foreground="#5A6A8A"
                                      Margin="0,0,24,0" Checked="ChkLZ_Invert_Checked"/>
                            <CheckBox x:Name="ChkLZ_MotorState"  Foreground="#5A6A8A"
                                      Content="Motor State"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Right Zone -->
                    <GroupBox Grid.Column="1"
                              Header="Right Zone"
                              Style="{StaticResource GroupBoxStyle}" FontWeight="Medium" Foreground="{StaticResource AccentBrush}"
                              Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal" Margin="2,2,2,2">
                            <CheckBox x:Name="ChkRZ_Invert"
                                      Content="Invert"
                                       Foreground="#5A6A8A"
                                      Margin="0,0,24,0"/>
                            <CheckBox x:Name="ChkRZ_MotorState"  Foreground="#5A6A8A"
                                      Content="Motor State"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </GroupBox>

            <!-- ══ Upstream / Downstream Accumulation ══ -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Upstream Accumulation -->
                <GroupBox Grid.Column="0"
                          Header="Upstream Accumulation"
                          Style="{StaticResource GroupBoxStyle}"  FontWeight="Black"  Foreground="{StaticResource AccentBrush}"
                          Margin="0,0,4,-6">
                    <CheckBox x:Name="ChkUpstreamAccumulate"  Foreground="#5A6A8A" FontWeight="Medium"
                              Content="Accumulate on Sensor Trigger"
                              Margin="2,2,2,2"/>
                </GroupBox>

                <!-- Downstream Accumulation -->
                <GroupBox Grid.Column="1"
                          Header="Downstream Accumulation"
                          Style="{StaticResource GroupBoxStyle}"  FontWeight="Black"   Foreground="{StaticResource AccentBrush}"
                          Margin="4,0,0,-6">
                    <CheckBox x:Name="ChkDownstreamAccumulate"  Foreground="#5A6A8A"  FontWeight="Medium" 
                              Content="Accumulate on Sensor Trigger"
                              Margin="2,2,2,2"/>
                </GroupBox>
            </Grid>

            <!-- ══ Lane Full Interface ══ -->
            <GroupBox Header="Lane Full Interface"  FontWeight="Black"   Foreground="{StaticResource AccentBrush}" Style="{StaticResource GroupBoxStyle}" Height="138">
                <StackPanel Margin="2,2,2,2">

                    <CheckBox x:Name="ChkLaneFull"
                              Content="Lane Full Interface"   FontWeight="Medium"  Foreground="#5A6A8A"
                              Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="RbFirstModule"
                                     Content="First Module"
                                     GroupName="LaneFullModule"  FontWeight="Medium" Foreground="#5A6A8A"
                                     IsEnabled="False"
                                     Margin="0,0,20,0"/>
                        <RadioButton x:Name="RbLastModule"
                                     Content="Last Module"
                                     GroupName="LaneFullModule" FontWeight="Medium" Foreground="#5A6A8A"
                                     IsEnabled="False"/>
                    </StackPanel>

                    <!-- Block Timer -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Block Timer:" Foreground="#5A6A8A"  FontWeight="Medium" 
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <TextBox x:Name="TxtBlockTimer"
                                 Style="{StaticResource TimerBox}"/>
                        <TextBlock Text=". sec"
                                   VerticalAlignment="Center" FontWeight="Medium"
                                   Margin="4,0,8,0"/>
                        <Button  x:Name="BtnBlockTimerSet" Grid.Column="2" Content="SET" Style="{StaticResource SetButton}"  Height="20">
                            <Button.Effect>
                                <DropShadowEffect Color="#5A6A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Button.Effect>
                        </Button>

                    </StackPanel>

                    <!-- Clear Timer -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Clear Timer:" FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <TextBox x:Name="TxtClearTimer"
                                 Style="{StaticResource TimerBox}"/>
                        <TextBlock Text=". sec" FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>
                        <Button  x:Name="BtnClearTimerSet" Grid.Column="2" Content="SET" Style="{StaticResource SetButton}"  Height="20">
                            <Button.Effect>
                                <DropShadowEffect Color="#5A6A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Button.Effect>
                        </Button>

                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <!-- ══ PLC Control checkboxes ══ -->
            <CheckBox x:Name="ChkPlcUpstream"  Foreground="#5A6A8A"  FontWeight="Medium" 
                      Content="Enable PLC Control of Upstream Control Port"
                      Margin="0,4,0,6"/>
            <CheckBox x:Name="ChkPlcDownstream"  Foreground="#5A6A8A"  FontWeight="Medium" 
                      Content="Enable PLC Control of Downstream Control Port"
                      Margin="0,0,0,4"/>

        </StackPanel>
    </Border>

</UserControl>