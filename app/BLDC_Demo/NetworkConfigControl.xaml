<UserControl x:Class="BLDC_Demo.NetworkConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="10" Padding="24,18">
        <StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Rectangle Width="2" Height="1" Fill="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0" RadiusX="2" RadiusY="2"/>
                <TextBlock Text="NETWORK &amp; DEVICE CONFIGURATION"
                           FontFamily="Arial Black" FontSize="11" FontWeight="Black"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Network Fields -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="▸ DEVICE ID" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" IsReadOnly="False"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="▸ NODE RANGE" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}" IsReadOnly="False"/>
                            <TextBlock Grid.Column="1" Text="—"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox Grid.Column="2" Style="{StaticResource DarkTextBox}" IsReadOnly="False"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="4">
                        <TextBlock Text="▸ SERIAL NO." Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" IsReadOnly="False"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="▸ FIRMWARE VERSION" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" IsReadOnly="True"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="▸ HARDWARE REVISION" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" IsReadOnly="True"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="4">
                        <TextBlock Text="▸ DEVICE STATUS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" IsReadOnly="True"/>
                    </StackPanel>
                </Grid>

                <!-- Connection Status panel -->
                <Border Grid.Column="2"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0" CornerRadius="8" Padding="18,10" Margin="0,-28,0,0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="140">


                       


                        <Button Content="ADVANCED" Style="{StaticResource AdvancedButton}"
                                HorizontalAlignment="Center">
                            <Button.Effect>
                                <DropShadowEffect Color="#5A6A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Button.Effect>
                        </Button>

                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Border>

</UserControl>
