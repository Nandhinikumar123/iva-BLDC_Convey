<UserControl x:Class="BLDC_Demo.LeftMdrControl"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d">
   
    <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="10" Padding="24,20">
        <StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                <Border Background="#E3F0FB" BorderBrush="{StaticResource BlueBrush}" BorderThickness="1"
                        CornerRadius="20" Padding="10,3" Margin="0,0,12,0">
                    <TextBlock Text="MDR-R" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource BlueBrush}"/>
                </Border>
                <TextBlock Text="LEFT MDR"
                           FontFamily="Arial Black" FontSize="11" FontWeight="Black"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="▸ MOTOR HALL TYPE" Style="{StaticResource FieldLabel}" Foreground="#5A6A8A"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox  x:Name="LeftMotorCombo" Grid.Column="0" Style="{StaticResource DarkComboBox}" Foreground="#64748B" SelectedIndex="{Binding LeftMotorHallTypeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"> 
                            <ComboBoxItem Content="Hall Sensor" Foreground="#5A6A8A"/>
                            <ComboBoxItem Content="Sensorless" Foreground="#5A6A8A"/>
                            <ComboBoxItem Content="Encoder" Foreground="#5A6A8A"/>
                        </ComboBox>
                        <Button Grid.Column="2" Content="SET" Style="{StaticResource SetButton}" Click="SetLeftMotorType_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="#5A6A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="▸ BRAKE METHOD" Style="{StaticResource FieldLabel}"  Foreground="#5A6A8A"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="LeftBrakeCombo" Foreground="#5A6A8A"
                  Grid.Column="0" 
                 Style="{StaticResource DarkComboBox}" 
          SelectedIndex="{Binding LeftBrakeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                            <ComboBoxItem Content="Normal"  Foreground="#5A6A8A"/>
                            <ComboBoxItem Content="Free"  Foreground="#5A6A8A"/>
                            <ComboBoxItem Content="ServoBreak"  Foreground="#5A6A8A"/>
                        </ComboBox>

                        <Button Grid.Column="2" Content="SET" Style="{StaticResource SetButton}" Click="SetLeftBrake_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="#5A6A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </StackPanel>


                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="▸ SPEED (%)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LeftSpeedTextBox"  Foreground="#5A6A8A" Grid.Column="0" Style="{StaticResource DarkTextBox}" IsReadOnly="False"/>
                        <Button Grid.Column="2" Content="SET" Style="{StaticResource SetButton}"  Click="SetSpeed_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="#5A6A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Text="▸ CURRENT (mA)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="LeftCurrentTextBox" Foreground="#5A6A8A" Style="{StaticResource DarkTextBox}" />
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="0">
                    <TextBlock Text="▸ ACCELERATION (sec)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LeftAccelTextBox" Foreground="#5A6A8A" Grid.Column="0" Style="{StaticResource DarkTextBox}" IsReadOnly="False"/>
                        <Button Grid.Column="2" Content="SET" Style="{StaticResource SetButton}"  Click="SetAccel_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="#5A6A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="2">
                    <TextBlock Text="▸ DECELERATION (sec)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LeftDecelTextBox"  Foreground="#5A6A8A" Grid.Column="0" Style="{StaticResource DarkTextBox}" IsReadOnly="False"/>
                        <Button Grid.Column="2" Content="SET" Style="{StaticResource SetButton}" Click="SetDecel_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="#5A6A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="WhiteSmoke" Margin="0,0,0,14"/>

            <Border Background="WhiteSmoke" BorderBrush="#D0D5E0" BorderThickness="1"
                    CornerRadius="8" Padding="16,14" Margin="0,0,0,14" Height="124">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="ERROR FLAGS" FontWeight="Bold" FontFamily="Consolas"
                                   FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="FlagHallSensor"  Style="{StaticResource StatusIndicatorStyle}" Tag="{Binding LeftHallSensorError}" Width="9" Height="9" StrokeThickness="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Hall Sensor Error" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="FlagOverCurrent"  Style="{StaticResource StatusIndicatorStyle}" Tag="{Binding LeftOverCurrent}" Width="9" Height="9" StrokeThickness="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Over Current" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="FlagOverVoltage" Style="{StaticResource StatusIndicatorStyle}"  Tag="{Binding LeftOverVoltage}" Width="9" Height="9" StrokeThickness="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Over Voltage" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="FlagUnderVoltage" Style="{StaticResource StatusIndicatorStyle}" Tag="{Binding LeftUnderVoltage}" Width="9" Height="9"  StrokeThickness="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Under Voltage" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="FlagMotorStalled" Style="{StaticResource StatusIndicatorStyle}" Tag="{Binding LeftMotorStalled}" Width="9" Height="9"  StrokeThickness="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Motor Stalled" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="FlagOverTemp" Style="{StaticResource StatusIndicatorStyle}" Tag="{Binding LeftOverTemperature}" Width="9" Height="9"  StrokeThickness="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Over Temperature" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Button x:Name="TripleStateButton" Content="▶  RUN  " HorizontalAlignment="Stretch" Width="82" Height="20"
                    Style="{StaticResource SetButton}" Click="TripleStateButton_Click">
                <Button.Effect>
                    <DropShadowEffect Color="#1565C0" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                </Button.Effect>
            </Button>

        </StackPanel>
    </Border>
</UserControl>