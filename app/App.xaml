<Application x:Class="BLDC_Demo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BLDC_Demo"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ═══════════════════════════════════════════
             BRUSHES
        ═══════════════════════════════════════════ -->
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="PanelBrush"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush"  Color="#D0D5E0"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#5A6A8A"/>
        <SolidColorBrush x:Key="BlueBrush"    Color="#1565C0"/>
        <SolidColorBrush x:Key="GreenBrush"   Color="#00C853"/>
        <SolidColorBrush x:Key="RedBrush"     Color="#FF1744"/>
        <SolidColorBrush x:Key="TextBrush"    Color="#1A2030"/>
        <SolidColorBrush x:Key="MutedBrush"   Color="#7A8AAA"/>
        <SolidColorBrush x:Key="LabelBrush"   Color="#5A6A8A"/>

        <!-- ═══════════════════════════════════════════
             FIELD LABEL
        ═══════════════════════════════════════════ -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <!-- ═══════════════════════════════════════════
             TEXT BOX
        ═══════════════════════════════════════════ -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#FFFFFF"/>
            <Setter Property="Foreground"               Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush"               Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="32"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="FontFamily"               Value="Consolas"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════
             COMBO BOX
        ═══════════════════════════════════════════ -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"  Value="#FFFFFF"/>
                        <Setter Property="Foreground"  Value="{StaticResource TextBrush}"/>
                        <Setter Property="FontFamily"  Value="Consolas"/>
                        <Setter Property="FontSize"    Value="13"/>
                        <Setter Property="Padding"     Value="10,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#D8F4FC"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#B3EAF8"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="10,0,0,0"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="▾"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Opacity="0"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#FFFFFF"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00C8FF" BlurRadius="12" ShadowDepth="0" Opacity="0.2"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DirectionComboBox" TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}">
            <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Width"           Value="200"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
        </Style>

        <!-- ═══════════════════════════════════════════
             BUTTONS
        ═══════════════════════════════════════════ -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D8F4FC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                              
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#5A6A8A"/>
            <Setter Property="Width"      Value="120"/>
            <Setter Property="Padding"    Value="20,0"/>
        </Style>

        <Style x:Key="AdvancedButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Width"           Value="100"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="{StaticResource LabelBrush}"/>
            <Setter Property="BorderBrush"     Value="White"/>
            <Setter Property="Padding"         Value="10,0"/>
        </Style>

        <Style x:Key="SetButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush"     Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="FontSize"        Value="10"/> 
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SetBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SetBd" Property="Background" Value="#D8F4FC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SetBd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#5A6A8A"/>
            <Setter Property="BorderBrush"     Value="White"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Width"           Value="150"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource StartButton}"/>

        <Style x:Key="RunButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding"    Value="16,0"/>
            <Setter Property="Height"     Value="40"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <!-- ═══════════════════════════════════════════
             MDR TITLE
        ═══════════════════════════════════════════ -->
        <Style x:Key="MdrTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>
        <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Fill" Value="#E8EAF0"/>
            <Setter Property="Stroke" Value="#C0C8D8"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="False">
                    <Setter Property="Fill" Value="#FF5252"/>
                    <Setter Property="Stroke" Value="#D32F2F"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                    <Setter Property="Fill" Value="#4CAF50"/>
                    <Setter Property="Stroke" Value="#2E7D32"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- ── NavTab ── -->
        <Style x:Key="NavTab" TargetType="TabItem">
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11.5"/>
            <Setter Property="Foreground"      Value="{StaticResource MutedBrush}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground"                   Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight"                   Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#EEF3FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

      

        <!-- Outer card GroupBox style -->
        <Style x:Key="CardGroup" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="12,8,12,12"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D0D5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2A3A5A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.RowSpan="2"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="8"
                              Background="{TemplateBinding Background}"
                              Margin="0,8,0,0"/>
                            <Border Grid.Row="0"
                              HorizontalAlignment="Left"
                              Margin="10,0,0,0"
                              Padding="4,0,4,0"
                              Background="#FFFFFF">
                                <ContentPresenter ContentSource="Header"
                                            RecognizesAccessKey="True"
                                            TextElement.FontSize="13"
                                            TextElement.FontWeight="SemiBold"
                                            TextElement.Foreground="#5A6A8A"/>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                        Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="BorderBrush"      Value="#888888"/>

            <Setter Property="Foreground"      Value="#5A6A8A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4,6,6"/>
            <Setter Property="Margin"           Value="0,0,0,8"/>
        </Style>

        <Style x:Key="TimerBox" TargetType="TextBox">
            <Setter Property="Width"                    Value="80"/>
            <Setter Property="Height"                   Value="22"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#ADADAD"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="2,0"/>
        </Style>
        <!-- Inner GroupBox style (Upstream / Downstream) -->
        <Style x:Key="InnerGroup" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Padding" Value="10,6,10,10"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D0D5E0"/>
            <Setter Property="BorderThickness" Value="1"/> 
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#5A6A8A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.RowSpan="2"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="6"
                              Background="{TemplateBinding Background}"
                              Margin="0,8,0,0"/>
                            <Border Grid.Row="0"
                              HorizontalAlignment="Left"
                              Margin="8,0,0,0"
                              Padding="4,0,4,0"
                              Background="#F0F4FC">
                                <ContentPresenter ContentSource="Header"
                                            RecognizesAccessKey="True"
                                            TextElement.FontSize="12"
                                            TextElement.Foreground="#5A6A8A"/>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                        Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sub GroupBox style (wraps Upstream/Downstream in Run After section) -->
        <Style x:Key="SubGroup" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Padding" Value="8,6,8,10"/>
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="BorderBrush" Value="#B0BCD4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#7A8AAA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.RowSpan="2"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="6"
                              Background="{TemplateBinding Background}"
                              Margin="0,8,0,0"/>
                            <Border Grid.Row="0"
                              HorizontalAlignment="Left"
                              Margin="8,0,0,0"
                              Padding="4,0,4,0"
                              Background="#F0F4FC">
                                <ContentPresenter ContentSource="Header"
                                            RecognizesAccessKey="True"
                                            TextElement.FontSize="11"
                                            TextElement.Foreground="#7A8AAA"/>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                        Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NumBox TextBox style -->
        <Style x:Key="NumBox" TargetType="TextBox">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#2A3A5A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#B0BCD4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Unit label style -->
        <Style x:Key="UnitLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8A9AB4"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Styled CheckBox -->
        <Style x:Key="StyledCheck" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="#2A3A5A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- ── Button Style ── -->
        <Style x:Key="StdBtn" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C8E0F4"/>
                                <Setter Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#9CC5E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Background" Value="#F4F4F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── IP Octet TextBox Style ── -->
        <Style x:Key="IpBox" TargetType="TextBox">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="MaxLength" Value="3"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ── Standard TextBox Style ── -->
        <Style x:Key="StdBox" TargetType="TextBox">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="3,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ── Field Label Style ── -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    

      

        <!-- ── Small browse button ───────────────────────── -->
        <Style x:Key="BrowseButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Width"    Value="26"/>
            <Setter Property="Height"   Value="20"/>
            <Setter Property="Padding"  Value="2,0"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <!-- ── Octet TextBox ─────────────────────────────── -->
        <Style x:Key="OctetBox" TargetType="TextBox">
            <Setter Property="Width"                    Value="32"/>
            <Setter Property="Height"                   Value="20"/>
            <Setter Property="MaxLength"                Value="3"/>
            <Setter Property="TextAlignment"            Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#ADADAD"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="0"/>
        </Style>

        <!-- ── Dot separator ─────────────────────────────── -->
        <Style x:Key="Dot" TargetType="TextBlock">
            <Setter Property="Text"              Value="."/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="1,0"/>
        </Style>

       


    </Application.Resources>
</Application>
